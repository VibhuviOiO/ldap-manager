# ============================================
# LDAP Manager with Keycloak + PostgreSQL (Production)
# ============================================

# Deployment Mode
AUTH_MODE=keycloak
READONLY_MODE=false  # Ignored in keycloak mode

# ============================================
# PostgreSQL Configuration
# ============================================

# PostgreSQL database credentials (CHANGE IN PRODUCTION!)
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=SecurePostgresPassword123!

# ============================================
# Keycloak Admin Credentials
# ============================================

# IMPORTANT: Change these in production!
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=SecureKeycloakPassword123!

# ============================================
# Keycloak Configuration
# ============================================

# Keycloak port
KEYCLOAK_PORT=8080

# Hostname (for production with reverse proxy)
# Example: auth.company.com
KC_HOSTNAME=localhost

# Backend Keycloak URL (internal service communication)
# For Docker Compose: http://keycloak:8080
# For external Keycloak: https://auth.company.com
KEYCLOAK_URL=http://keycloak:8080

# JWT Issuer (must match token issuer claim)
# For local: http://localhost:8080/realms/ldap-manager
# For production: https://auth.company.com/realms/ldap-manager
KEYCLOAK_ISSUER=http://localhost:8080/realms/ldap-manager

# Keycloak realm and client
KEYCLOAK_REALM=ldap-manager
KEYCLOAK_CLIENT_ID=ldap-manager-client

# ============================================
# Frontend Keycloak Configuration
# ============================================

# Browser-accessible Keycloak URL
# Must be accessible from user's browser
# For local: http://localhost:8080
# For production: https://auth.company.com
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=ldap-manager
VITE_KEYCLOAK_CLIENT_ID=ldap-manager-client

# ============================================
# CORS Configuration
# ============================================

# Allowed origins (comma-separated)
# Production example: https://ldap.company.com,https://auth.company.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=INFO
JSON_LOGS=true

# ============================================
# Rate Limiting
# ============================================

# Redis URL for distributed rate limiting
# Use "memory://" for single instance
# Use "redis://redis:6379" for multi-instance with Redis
# Uncomment redis service in docker-compose.prod.yml if using Redis
REDIS_URL=memory://

# ============================================
# UI Configuration
# ============================================

VITE_FOOTER_TEXT=LDAP Manager • Built by <a href="https://vibhuvioio.com" target="_blank" class="text-primary hover:underline">Vibhuvi OiO</a>

# ============================================
# Optional: Context Path
# ============================================

# For reverse proxy deployment
# Example: /ldap for https://company.com/ldap
CONTEXT_PATH=

# ============================================
# Production Notes
# ============================================

# 1. PostgreSQL Backend:
#    - Production-grade database
#    - Better performance than H2
#    - Supports horizontal scaling (multiple Keycloak instances)
#    - Proper replication and backups
#
# 2. Suitable for:
#    - Large deployments (> 100 users)
#    - High availability requirements
#    - Multiple Keycloak instances (load balanced)
#    - Enterprise environments
#
# 3. Security Checklist:
#    - Change POSTGRES_PASSWORD (strong password)
#    - Change KEYCLOAK_ADMIN_PASSWORD (strong password)
#    - Use HTTPS with reverse proxy
#    - Enable PostgreSQL SSL/TLS
#    - Regular database backups
#    - Monitor database performance
#
# 4. Performance Tuning:
#    - Increase Keycloak memory: JAVA_OPTS_APPEND=-Xms1g -Xmx2g
#    - Tune PostgreSQL settings (shared_buffers, work_mem)
#    - Use connection pooling
#    - Enable query caching
#
# 5. High Availability Setup:
#    - Multiple Keycloak instances (load balanced)
#    - PostgreSQL primary-replica replication
#    - Redis for shared sessions
#    - Health checks and auto-restart
#
# 6. Backup Strategy:
#    - Daily PostgreSQL backups (pg_dump)
#    - Retain backups for 30 days
#    - Test restore procedures
#    - Off-site backup storage
#
# 7. Test users (pre-configured in realm):
#    - admin / admin123 (full access)
#    - editor / editor123 (read + write)
#    - viewer / viewer123 (read-only)
#    - auditor / auditor123 (logs only)
#    DELETE THESE IN PRODUCTION!
