# ============================================
# LDAP Manager - Read-Write Mode (Production)
# ============================================

# Deployment Mode
AUTH_MODE=legacy
READONLY_MODE=false

# ============================================
# CORS Configuration
# ============================================

# Allowed origins (comma-separated)
# Production: Use your actual domain(s)
# Example: https://ldap.company.com,https://ldap-backup.company.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=INFO
JSON_LOGS=true

# ============================================
# UI Configuration
# ============================================

VITE_FOOTER_TEXT=LDAP Manager • Built by <a href="https://vibhuvioio.com" target="_blank" class="text-primary hover:underline">Vibhuvi OiO</a>

# ============================================
# Optional: Context Path
# ============================================

# For reverse proxy deployment
# Example: /ldap for https://company.com/ldap
CONTEXT_PATH=

# ============================================
# Production Notes
# ============================================

# 1. This mode provides FULL READ-WRITE access without authentication
# 2. Users can view, create, edit, and delete entries
# 3. Users can configure LDAP connections (enter passwords)
# 4. Suitable for:
#    - Internal corporate networks (trusted users)
#    - Development environments
#    - Small teams with known users
#    - Air-gapped networks
#
# 5. Security Notes:
#    ⚠️  CRITICAL: Anyone with network access has FULL ADMIN ACCESS
#    ⚠️  DO NOT expose to public internet
#    - Deploy behind VPN or firewall (required)
#    - Use IP whitelist
#    - Monitor all access and changes
#    - Regular backups (daily recommended)
#    - Use HTTPS with reverse proxy
#
# 6. For production deployment:
#    - Firewall is MANDATORY (allow specific IPs only)
#    - HTTPS via reverse proxy (nginx/Caddy)
#    - Enable audit logging
#    - Regular security audits
#    - Consider switching to Keycloak mode for better security
