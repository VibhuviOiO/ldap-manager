# ============================================
# LDAP Manager with Keycloak (Production)
# ============================================

# Deployment Mode
AUTH_MODE=keycloak
READONLY_MODE=false  # Ignored in keycloak mode

# ============================================
# Keycloak Admin Credentials
# ============================================

# IMPORTANT: Change these in production!
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ============================================
# Keycloak Configuration
# ============================================

# Keycloak port
KEYCLOAK_PORT=8080

# Hostname (for production with reverse proxy)
# Example: auth.company.com
KC_HOSTNAME=localhost

# Backend Keycloak URL (internal service communication)
# For Docker Compose: http://keycloak:8080
# For external Keycloak: https://auth.company.com
KEYCLOAK_URL=http://keycloak:8080

# JWT Issuer (must match token issuer claim)
# For local: http://localhost:8080/realms/ldap-manager
# For production: https://auth.company.com/realms/ldap-manager
KEYCLOAK_ISSUER=http://localhost:8080/realms/ldap-manager

# Keycloak realm and client
KEYCLOAK_REALM=ldap-manager
KEYCLOAK_CLIENT_ID=ldap-manager-client

# ============================================
# Frontend Keycloak Configuration
# ============================================

# Browser-accessible Keycloak URL
# Must be accessible from user's browser
# For local: http://localhost:8080
# For production: https://auth.company.com
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=ldap-manager
VITE_KEYCLOAK_CLIENT_ID=ldap-manager-client

# ============================================
# CORS Configuration
# ============================================

# Allowed origins (comma-separated)
# Production example: https://ldap.company.com,https://auth.company.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=INFO
JSON_LOGS=true

# ============================================
# Rate Limiting
# ============================================

# Redis URL for distributed rate limiting
# Use "memory://" for single instance (default)
# Use "redis://redis:6379" for multi-instance setup
REDIS_URL=memory://

# ============================================
# UI Configuration
# ============================================

VITE_FOOTER_TEXT=LDAP Manager • Built by <a href="https://vibhuvioio.com" target="_blank" class="text-primary hover:underline">Vibhuvi OiO</a>

# ============================================
# Optional: Context Path
# ============================================

# For reverse proxy deployment
# Example: /ldap for https://company.com/ldap
CONTEXT_PATH=

# ============================================
# Production Notes
# ============================================

# 1. This mode provides AUTHENTICATED access with Role-Based Access Control
# 2. Four roles:
#    - admin: Full access + LDAP configuration
#    - editor: Read + write (cannot delete or configure LDAP)
#    - viewer: Read-only access
#    - auditor: Logs and monitoring access
#
# 3. Admin-only LDAP configuration:
#    - Only admin users can configure LDAP passwords
#    - Admin enters password once, all users share connection
#    - Non-admin users never see LDAP passwords
#
# 4. Security features:
#    - JWT token validation with Keycloak JWKS
#    - Auto token refresh (15-min access, 7-day refresh)
#    - Rate limiting (100 req/min per IP, 1000 req/hour per user)
#    - Audit trail with usernames
#
# 5. Test users (pre-configured in realm):
#    - admin / admin123 (full access)
#    - editor / editor123 (read + write)
#    - viewer / viewer123 (read-only)
#    - auditor / auditor123 (logs only)
#
# 6. For production deployment:
#    - Change KEYCLOAK_ADMIN_PASSWORD
#    - Create real users in Keycloak Admin Console
#    - Delete test users
#    - Use HTTPS with reverse proxy
#    - Consider external Keycloak or PostgreSQL backend
#    - Enable monitoring and alerting
#
# 7. H2 Database Limits:
#    - Embedded H2 database (suitable for < 100 users)
#    - For larger deployments, use PostgreSQL
#    - See use-cases/ldap-manager-with-keycloak-postgres/
