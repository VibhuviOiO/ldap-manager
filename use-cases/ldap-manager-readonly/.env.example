# ============================================
# LDAP Manager - Read-Only Mode (Production)
# ============================================

# Deployment Mode
AUTH_MODE=legacy
READONLY_MODE=true

# ============================================
# CORS Configuration
# ============================================

# Allowed origins (comma-separated)
# Production: Use your actual domain(s)
# Example: https://ldap.company.com,https://ldap-backup.company.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=INFO
JSON_LOGS=true

# ============================================
# UI Configuration
# ============================================

VITE_FOOTER_TEXT=LDAP Manager (Read-Only) • Built by <a href="https://vibhuvioio.com" target="_blank" class="text-primary hover:underline">Vibhuvi OiO</a>

# ============================================
# Optional: Context Path
# ============================================

# For reverse proxy deployment
# Example: /ldap for https://company.com/ldap
CONTEXT_PATH=

# ============================================
# Production Notes
# ============================================

# 1. This mode provides READ-ONLY access without authentication
# 2. Users can view entries, search, and see statistics
# 3. Users CANNOT create, edit, or delete entries
# 4. Suitable for:
#    - Public dashboards
#    - Network operations centers (NOC)
#    - Monitoring displays
#    - Kiosks or shared screens
#
# 5. Security Notes:
#    - Anyone with network access can VIEW data
#    - Deploy behind VPN or firewall for sensitive data
#    - Use HTTPS with reverse proxy (nginx/Caddy)
#    - LDAP passwords must be pre-configured in config.yml
#
# 6. For production deployment:
#    - Use reverse proxy for HTTPS
#    - Configure firewall rules
#    - Enable monitoring and alerting
#    - Regular security audits
