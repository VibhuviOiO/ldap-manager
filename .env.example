# LDAP Manager Environment Variables

# ============================================
# Application Configuration
# ============================================

# Context path for reverse proxy deployment (optional)
# Example: /ldap-manager for https://example.com/ldap-manager
CONTEXT_PATH=

# CORS allowed origins (comma-separated)
# Example: https://ldap.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Logging configuration
LOG_LEVEL=INFO
JSON_LOGS=false

# Server port
PORT=8000

# ============================================
# Deployment Modes (Choose ONE)
# ============================================

# MODE 1: Keycloak Authentication (Recommended for Production)
# - User authentication required via Keycloak
# - Role-based access control (admin, editor, viewer, auditor)
# - Audit trail with username tracking
# AUTH_MODE=keycloak
# READONLY_MODE=false

# MODE 2: No Authentication + Read-Only
# - No login required
# - All users have viewer access only
# - Suitable for public dashboards or monitoring
# AUTH_MODE=legacy
# READONLY_MODE=true

# MODE 3: No Authentication + Full Access (V1 Compatibility)
# - No login required
# - All users have admin access (create, edit, delete)
# - Suitable for trusted internal networks only
# AUTH_MODE=legacy
# READONLY_MODE=false

# ============================================
# Keycloak Authentication Configuration
# ============================================

# Backend Keycloak Configuration (internal service URL)
# For Docker Compose: http://keycloak:8080
# For external Keycloak: https://auth.company.com
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=ldap-manager
KEYCLOAK_CLIENT_ID=ldap-manager-client

# JWT issuer validation (browser-accessible URL)
# Must match the issuer claim in JWT tokens
# For local dev: http://localhost:8080/realms/ldap-manager
# For production: https://auth.company.com/realms/ldap-manager
KEYCLOAK_ISSUER=http://localhost:8080/realms/ldap-manager

# Authentication mode: "keycloak" or "legacy"
# - keycloak: Requires login via Keycloak (MODE 1)
# - legacy: No authentication (MODE 2 or MODE 3, depends on READONLY_MODE)
AUTH_MODE=keycloak

# Read-only mode: "true" or "false"
# Only applies when AUTH_MODE=legacy
# - true: All users get viewer access only (MODE 2)
# - false: All users get admin access (MODE 3)
READONLY_MODE=false

# Development mode: "true" to allow optional authentication in dev
DEVELOPMENT_MODE=false

# Frontend Keycloak Configuration (browser-accessible URL)
# Must be accessible from user's browser
# For local dev: http://localhost:8080
# For production: https://auth.company.com
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=ldap-manager
VITE_KEYCLOAK_CLIENT_ID=ldap-manager-client

# ============================================
# Rate Limiting (Optional)
# ============================================

# Redis URL for distributed rate limiting
# Use "memory://" for in-memory (single instance)
# Use "redis://redis:6379" for Redis
REDIS_URL=memory://

# ============================================
# UI Configuration
# ============================================

# Footer text (supports HTML)
VITE_FOOTER_TEXT=LDAP Manager • Built by <a href="https://vibhuvioio.com" target="_blank" class="text-primary hover:underline">Vibhuvi OiO</a>

# ============================================
# Security Notes
# ============================================

# IMPORTANT: Never commit actual secrets to version control
# Add .env to .gitignore

# Test Users (preconfigured in Keycloak realm):
# - admin / admin123 (full access)
# - editor / editor123 (read + write)
# - viewer / viewer123 (read-only)
# - auditor / auditor123 (logs only)

# Production Checklist:
# 1. Change default Keycloak admin password
# 2. Create real users and delete test accounts
# 3. Use HTTPS with reverse proxy (nginx/Caddy)
# 4. Set KEYCLOAK_URL to external Keycloak instance
# 5. Configure proper CORS origins
# 6. Enable JSON_LOGS=true for production
# 7. Use Redis for rate limiting in multi-instance setup
